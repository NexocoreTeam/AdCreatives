# fal.ai - Image and video generation
FAL_KEY=your_fal_key_here

# OpenAI - GPT-4o vision for reference analysis, VOC analysis
OPENAI_API_KEY=your_openai_key_here

# Anthropic - Claude for strategy, copy, briefs
ANTHROPIC_API_KEY=your_anthropic_key_here

# Higgs Field - Soul Character identity-locked image generation
# Used by `adc remix-images --engine higgsfield-soul` and staged-mode pass 3.
# Get keys at https://platform.higgsfield.ai (Settings -> API Keys).
# The MCP OAuth session token is NOT a REST API key - they don't interchange.
# Provide EITHER the single-field form below, OR the split HF_API_KEY +
# HF_API_SECRET pair. The client prefers HF_CREDENTIALS if both are set.
HF_CREDENTIALS=your_hf_key_id:your_hf_key_secret
# HF_API_KEY=your_hf_key_id
# HF_API_SECRET=your_hf_key_secret

# OpenRouter - multi-image vision via Gemini 2.5 Pro for visual identity capture
# Falls back to Claude vision (single image) if not set.
OPENROUTER_API_KEY=your_openrouter_key_here

# Optional: Apify - Meta Ad Library scraping
APIFY_API_TOKEN=your_apify_token_here

# Optional: Reddit - VOC mining from subreddits
REDDIT_CLIENT_ID=your_reddit_client_id
REDDIT_CLIENT_SECRET=your_reddit_client_secret
REDDIT_USER_AGENT=adcreatives/0.1

# Optional: Google Drive integration - service account JSON key path
# Used by `adc enrich-brand` and `adc analyze-references` to pull assets from
# a per-client Drive folder. Service account must have Viewer access to each
# client folder. Store the JSON OUTSIDE the repo (e.g. ~/.gcloud/) so it never
# gets committed by accident.
GOOGLE_APPLICATION_CREDENTIALS=/absolute/path/to/your-service-account.json

# Foreplay - ad library / swipe file sync (public + internal API both accept this token)
FOREPLAY_API_KEY=your_foreplay_key_here

# Exa - Neural web search for unfiltered VoC + competitor reviews
EXA_API_KEY=your_exa_key_here
