output/
.env
__pycache__/
*.pyc
.ruff_cache/
.pytest_cache/
dist/
*.egg-info/
competitors/cache/
clients/*/voc/*.json
# Drive ingestion: cached Drive file analyses (keyed by file_id + modifiedTime).
# Local-only; regenerated on demand.
clients/*/.drive_cache/
# Scratch directory for one-off generated assets (PDFs, images via fal.ai).
# Test fixtures, not committed.
scratch/

# Per-client output directories. Only the canonical template + intentionally-
# committed test clients live in git. New `adc init-client` / `adc research`
# runs create local-only working dirs that should not clutter `git status`.
clients/*/
!clients/_template/
!clients/magic-spoon/
!clients/olipop/
!clients/sbg-co/
!clients/sbg-co-fresh/
!clients/secondkind/

# Cost log per client — append-only, regenerable, not source-of-truth
clients/*/.cost-log.jsonl

# Ad-remixer output — per-run analysis / briefs / prompts / images.
# Regenerable from `adc remix` and `adc remix-images`; not source-of-truth.
clients/*/remixes/

# Reference images uploaded via the dashboard's Remix tab — local-only.
references/_dashboard_uploads/

# Scratch / temp logs from CLI runs — regenerable, not source-of-truth
.tmp_*
*.bak
*.yaml.bak

# Generated ad outputs (binary PNGs, large) — regenerable via `adc generate`
ai-ads/

# Source reference ad images — pulled from Drive on demand; large binaries.
# Their per-file analyses (analyses/) ARE committed since they're small YAML.
clients/*/reference_ads/raw/

# Agent skill packs installed via `npx skills add` — machine-local skill
# sources + Claude Code symlinks. Each developer installs their own via
# `npx skills add higgsfield-ai/skills`; not source-of-truth.
.agents/
.claude/skills/
